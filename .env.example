# FRONTEND ENVIRONMENT VARIABLES
# =================================

# API Configuration
# Use your deployed backend API URL (must be HTTPS in production)
VITE_API_URL=https://api.yourdomain.com

# Google Analytics (optional)
VITE_GA_ID=

# Feature Flags
VITE_ENABLE_DEBUG=false


# BACKEND ENVIRONMENT VARIABLES (Server-side, AWS EC2)
# ====================================================

# Server Port
SERVER_PORT=8080

# Database Configuration (AWS RDS MySQL)
# Use IAM authentication or strong passwords
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=forgelabs_production
DB_USERNAME=admin_user
DB_PASSWORD=GENERATE_A_STRONG_PASSWORD_MIN_32_CHARS

# JWT Configuration
# Use a strong secret (minimum 64 characters, random alphanumeric)
JWT_SECRET=GENERATE_A_STRONG_JWT_SECRET_MIN_64_CHARS_WITH_SPECIAL_CHARS
# JWT expiration in milliseconds (default: 7 days = 604800000ms)
JWT_EXPIRATION=604800000

# CORS Configuration
# Comma-separated list of allowed origins (production domain only)
FRONTEND_URL=https://www.yourdomain.com,https://yourdomain.com

# Encryption Key (for sensitive data encryption)
# Use a random 32-character string
ENCRYPTION_KEY=GENERATE_A_RANDOM_32_CHAR_ENCRYPTION_KEY

# Claude AI Configuration (for AI features)
CLAUDE_API_KEY=sk-ant-api03-your-api-key-here

# Logging Configuration
LOGGING_LEVEL=WARN
LOGGING_FILE_PATH=/var/log/forgelabs/app.log
LOGGING_MAX_FILE_SIZE=10MB
LOGGING_MAX_HISTORY=30

# Security Configuration
HTTPS_ONLY=true
SECURE_COOKIES=true
SAME_SITE_COOKIES=Strict
